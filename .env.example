# Safe local defaults only. Do not commit real secrets.

POSTGRES_DB=social_hunter
POSTGRES_USER=social_hunter
POSTGRES_PASSWORD=local_dev_only_change_me
DATABASE_URL=postgresql+asyncpg://social_hunter:local_dev_only_change_me@postgres:5432/social_hunter
REDIS_URL=redis://redis:6379/0

API_CORS_ORIGINS=http://localhost:5173
API_PUBLIC_BASE_URL=http://localhost:8000

# Use OpenClaw Vault references in production. Do not paste raw API keys here.
HIBP_API_KEY_REF=REPLACE_WITH_VAULT_REFERENCE
IPINFO_TOKEN_REF=REPLACE_WITH_VAULT_REFERENCE
HUNTER_API_KEY_REF=REPLACE_WITH_VAULT_REFERENCE
